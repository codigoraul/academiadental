---
import Layout from '../layouts/Layout.astro';
import CourseCard from '../components/CourseCard.astro';
import { getCursos, getFeaturedImage } from '../lib/wp';

const cursos = await getCursos({ per_page: '3' });
---

<Layout title="Academia Dental — Formación Clínica de Alto Nivel" description="Cursos de odontología presenciales y híbridos dictados por especialistas. Formación continua de alto nivel para odontólogos.">

  <!-- HERO -->
  <section id="hero" class="relative text-white py-24 px-6 overflow-hidden" style="background-image: url('/images/hero-bg-temuco.webp'); background-size: cover; background-position: center;">
    <div class="absolute inset-0" style="background: linear-gradient(135deg, #143475F0 0%, rgba(10, 35, 84, 0.7) 50%, rgba(20, 42, 69, 0.78) 100%);"></div>
    <div class="relative z-10 max-w-7xl mx-auto grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <span class="inline-block bg-white/20 text-white text-sm font-medium px-4 py-1.5 rounded-full mb-6">
          🎓 Clínica Milenium — Formación Continua
        </span>
        <h1 class="text-4xl lg:text-5xl font-extrabold leading-tight mb-6">
          Formación Clínica de Alto Nivel para Odontólogos
        </h1>
        <p class="text-xl text-blue-100 mb-8 leading-relaxed">
          Cursos presenciales y híbridos dictados por especialistas. Aprende, practica y certifícate.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/cursos" class="bg-white text-primary font-bold px-7 py-3.5 rounded-full hover:bg-blue-50 transition-colors">
            Ver Cursos
          </a>
          <a href="/contacto" class="border-2 border-white text-white font-bold px-7 py-3.5 rounded-full hover:bg-white/10 transition-colors">
            Contáctanos
          </a>
        </div>
      </div>
      <!-- Cards flotantes decorativas -->
      <div class="hidden lg:grid grid-cols-2 gap-4">
        {['Ortodoncia Avanzada', 'Rehabilitación Estética', 'Odontología Digital', 'Endodoncia'].map((nombre, i) => (
          <div class={`bg-white/10 backdrop-blur-sm border border-white/20 rounded-2xl p-5 ${i % 2 !== 0 ? 'mt-6' : ''}`}>
            <div class="w-8 h-8 bg-white/20 rounded-lg mb-3"></div>
            <p class="font-semibold text-sm">{nombre}</p>
            <p class="text-xs text-blue-200 mt-1">Próximo curso disponible</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- VENTAJAS -->
  <section class="py-20 px-6 bg-white">
    <div class="max-w-7xl mx-auto text-center mb-12">
      <h2 class="text-3xl font-extrabold text-dark mb-4">¿Por qué Academia Dental?</h2>
      <p class="text-gray-500 max-w-2xl mx-auto">Tres pilares que hacen la diferencia en tu formación continua.</p>
    </div>
    <div class="max-w-7xl mx-auto grid md:grid-cols-3 gap-8">
      {[
        {
          icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>`,
          title: 'Docentes Especialistas',
          desc: 'Profesionales activos con experiencia clínica real, referentes en su área de especialidad.',
        },
        {
          icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>`,
          title: 'Práctica Hands-On',
          desc: 'Metodología enfocada en el hacer, no solo el escuchar. Casos clínicos reales desde el primer módulo.',
        },
        {
          icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>`,
          title: 'Certificación Avalada',
          desc: 'Certificados que respaldan tu formación continua y potencian tu perfil profesional.',
        },
      ].map(item => (
        <div class="text-center p-8 rounded-2xl border border-light hover:shadow-md transition-shadow">
          <div class="w-14 h-14 bg-blue-50 rounded-2xl flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" set:html={item.icon} />
          </div>
          <h3 class="font-bold text-dark text-lg mb-3">{item.title}</h3>
          <p class="text-gray-500 text-sm leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- CURSOS DESTACADOS -->
  <section class="py-20 px-6 bg-[#F9F9F9]">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-end justify-between mb-10">
        <div>
          <h2 class="text-3xl font-extrabold text-dark mb-2">Cursos Destacados</h2>
          <p class="text-gray-500">Selección de nuestros programas más solicitados.</p>
        </div>
        <a href="/cursos" class="hidden md:inline-flex items-center gap-2 text-primary font-semibold text-sm hover:text-secondary transition-colors">
          Ver todos <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
      {cursos.length > 0 ? (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {cursos.map((curso: any) => (
            <CourseCard
              title={curso.title?.rendered ?? curso.title}
              slug={curso.slug}
              image={getFeaturedImage(curso)}
              categoria={curso.acf?.modalidad ?? ''}
              modalidad={curso.acf?.modalidad ?? ''}
              fecha={curso.acf?.fecha ?? ''}
              precio={curso.acf?.precio ?? ''}
            />
          ))}
        </div>
      ) : (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {['Ortodoncia Avanzada Clínica', 'Rehabilitación Estética Full Mouth', 'Odontología Digital & CAD/CAM'].map((nombre) => (
            <div class="bg-white rounded-2xl border border-light p-6 shadow-sm">
              <div class="h-40 bg-light rounded-xl mb-4 flex items-center justify-center">
                <svg class="w-12 h-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
              </div>
              <span class="inline-block bg-secondary text-white text-xs font-semibold px-3 py-1 rounded-full mb-3">Curso</span>
              <h3 class="font-bold text-dark mb-4">{nombre}</h3>
              <a href="/cursos" class="block text-center bg-primary hover:bg-secondary text-white text-sm font-semibold py-2.5 rounded-xl transition-colors">Ver más</a>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- METODOLOGÍA RESUMIDA -->
  <section class="py-20 px-6 bg-primary text-white">
    <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="text-3xl font-extrabold mb-4">Nuestra Metodología</h2>
        <p class="text-blue-100 leading-relaxed mb-6">
          Cada programa está diseñado para llevar el conocimiento teórico directamente a la práctica clínica. Trabajamos con pequeños grupos para garantizar una experiencia personalizada de alto impacto.
        </p>
        <a href="/metodologia" class="inline-flex items-center gap-2 text-white font-semibold border-b border-white/50 hover:border-white pb-0.5 transition-colors">
          Conoce más <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
      <div class="grid grid-cols-2 gap-4">
        {[
          { icon: '🏥', title: 'Presencial Hands-On', desc: 'Práctica directa en clínica desde el primer módulo.' },
          { icon: '💻', title: 'Modelo Híbrido', desc: 'Teoría online + práctica presencial en sede.' },
          { icon: '🦷', title: 'Práctica Clínica', desc: 'Atención de pacientes reales bajo supervisión.' },
          { icon: '📦', title: 'Material Entregado', desc: 'Kit completo de instrumental y material de estudio.' },
        ].map(item => (
          <div class="bg-white/10 border border-white/20 rounded-2xl p-5">
            <div class="text-2xl mb-3">{item.icon}</div>
            <h4 class="font-bold text-sm mb-1">{item.title}</h4>
            <p class="text-xs text-blue-200 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="py-20 px-6 bg-light">
    <div class="max-w-4xl mx-auto text-center mb-12">
      <h2 class="text-3xl font-extrabold text-dark mb-4">¿Listo para dar el siguiente paso en tu carrera?</h2>
      <p class="text-gray-500">Completa el formulario y te contactamos con toda la información del curso que te interesa.</p>
    </div>
    <div class="max-w-2xl mx-auto bg-white rounded-2xl shadow-sm border border-light p-8">
      <form class="space-y-4" action="#" method="POST">
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-dark mb-1">Nombre</label>
            <input type="text" name="nombre" placeholder="Tu nombre completo" required
              class="w-full border border-light rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition" />
          </div>
          <div>
            <label class="block text-sm font-medium text-dark mb-1">Email</label>
            <input type="email" name="email" placeholder="tu@email.com" required
              class="w-full border border-light rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition" />
          </div>
        </div>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-dark mb-1">Teléfono</label>
            <input type="tel" name="telefono" placeholder="+56 9 ..."
              class="w-full border border-light rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition" />
          </div>
          <div>
            <label class="block text-sm font-medium text-dark mb-1">Curso de interés</label>
            <select name="curso" class="w-full border border-light rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition bg-white">
              <option value="">Seleccionar...</option>
              <option>Ortodoncia</option>
              <option>Rehabilitación</option>
              <option>Odontología Digital</option>
              <option>Endodoncia</option>
            </select>
          </div>
        </div>
        <button type="submit" class="w-full bg-primary hover:bg-secondary text-white font-bold py-3.5 rounded-xl transition-colors">
          Enviar consulta
        </button>
      </form>
      <div class="text-center mt-6">
        <span class="text-gray-400 text-sm">o contáctanos directo por</span>
        <a
          href="https://wa.me/56912345678"
          target="_blank"
          class="flex items-center justify-center gap-2 mt-3 bg-green-500 hover:bg-green-400 text-white font-semibold py-3 rounded-xl transition-colors"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp
        </a>
      </div>
    </div>
  </section>

</Layout>
