---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Contacto — Academia Dental" description="Contáctanos para más información sobre nuestros cursos de odontología. Temuco, Chile.">

  <PageHero
    title="Contacto"
    breadcrumb={[{ label: 'Contacto' }]}
    image="/images/bg-contacto.webp"
    imagePosition="center 35%"
  />

  <section class="py-20 px-6 bg-[#F9F9F9]">
    <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-12">

      <!-- Formulario -->
      <div class="bg-white rounded-2xl border border-light p-8 shadow-sm">
        <h2 class="text-2xl font-extrabold text-dark mb-6">Envíanos un mensaje</h2>
        <form class="space-y-5" action="#" method="POST">
          <div>
            <label class="block text-sm font-medium text-dark mb-1">Nombre completo</label>
            <input type="text" name="nombre" placeholder="Tu nombre" required
              class="w-full border border-light rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition" />
          </div>
          <div>
            <label class="block text-sm font-medium text-dark mb-1">Correo electrónico</label>
            <input type="email" name="email" placeholder="tu@email.com" required
              class="w-full border border-light rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition" />
          </div>
          <div>
            <label class="block text-sm font-medium text-dark mb-1">Teléfono</label>
            <input type="tel" name="telefono" placeholder="+56 9 ..."
              class="w-full border border-light rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition" />
          </div>
          <div>
            <label class="block text-sm font-medium text-dark mb-1">Mensaje</label>
            <textarea name="mensaje" rows="4" placeholder="¿En qué podemos ayudarte?"
              class="w-full border border-light rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition resize-none"></textarea>
          </div>
          <button type="submit"
            class="w-full bg-primary hover:bg-secondary text-white font-bold py-3.5 rounded-xl transition-colors">
            Enviar mensaje
          </button>
        </form>
      </div>

      <!-- Info de contacto -->
      <div class="space-y-8">
        <div>
          <h2 class="text-2xl font-extrabold text-dark mb-6">Información de contacto</h2>
          <ul class="space-y-5">
            <li class="flex items-start gap-4">
              <div class="w-10 h-10 bg-blue-50 rounded-xl flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-dark text-sm">Dirección</p>
                <p class="text-gray-500 text-sm">Temuco, Chile</p>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <div class="w-10 h-10 bg-blue-50 rounded-xl flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-dark text-sm">Teléfono / WhatsApp</p>
                <a href="tel:+56912345678" class="text-secondary text-sm hover:underline">+56 9 1234 5678</a>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <div class="w-10 h-10 bg-blue-50 rounded-xl flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-dark text-sm">Correo electrónico</p>
                <a href="mailto:contacto@academiadental.cl" class="text-secondary text-sm hover:underline">contacto@academiadental.cl</a>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <div class="w-10 h-10 bg-blue-50 rounded-xl flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-dark text-sm">Horario de atención</p>
                <p class="text-gray-500 text-sm">Lunes a Viernes, 9:00 – 18:00 hrs.</p>
              </div>
            </li>
          </ul>
        </div>

       

        <!-- Redes sociales -->
        <div>
          <p class="text-sm font-semibold text-dark mb-3">Síguenos en redes sociales</p>
          <div class="flex gap-3">
            <a href="#" aria-label="Instagram" target="_blank" class="w-10 h-10 rounded-full bg-primary hover:bg-secondary flex items-center justify-center transition-colors">
              <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
            </a>
            <a href="#" aria-label="Facebook" target="_blank" class="w-10 h-10 rounded-full bg-primary hover:bg-secondary flex items-center justify-center transition-colors">
              <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>
            <a href="#" aria-label="LinkedIn" target="_blank" class="w-10 h-10 rounded-full bg-primary hover:bg-secondary flex items-center justify-center transition-colors">
              <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- Mapa embed placeholder -->
        <div class="bg-light rounded-2xl h-48 flex items-center justify-center border border-light">
          <div class="text-center text-gray-400">
            <svg class="w-10 h-10 mx-auto mb-2 opacity-40" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
            </svg>
            <p class="text-sm">Mapa de ubicación</p>
            <p class="text-xs mt-1">Temuco, Chile</p>
          </div>
        </div>
      </div>

    </div>
  </section>

</Layout>
