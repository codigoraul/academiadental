---
import Layout from '../../layouts/Layout.astro';
import CourseCard from '../../components/CourseCard.astro';
import PageHero from '../../components/PageHero.astro';
import { getDocentes, getDocenteBySlug, getCursoById, getFeaturedImage } from '../../lib/wp';

export async function getStaticPaths() {
  const docentes = await getDocentes();
  return docentes.map((d: any) => ({ params: { slug: d.slug } }));
}

const { slug } = Astro.params;
const docente = await getDocenteBySlug(slug!);
if (!docente) return Astro.redirect('/docentes');

const acf = docente.acf ?? {};
const nombre = docente.title?.rendered ?? docente.title ?? '';
const foto = acf.foto?.url ?? getFeaturedImage(docente);

// Obtener datos completos de los cursos relacionados
const cursosRelacionadosRaw = Array.isArray(acf.cursos_relacionados) ? acf.cursos_relacionados : [];
const cursosRelacionados = await Promise.all(
  cursosRelacionadosRaw.map(async (curso: any) => {
    // Si el curso es solo un ID, obtener los datos completos
    if (typeof curso === 'number' || curso.ID) {
      const cursoId = typeof curso === 'number' ? curso : curso.ID;
      return await getCursoById(cursoId);
    }
    // Si ya tiene los datos, devolverlo tal cual
    return curso;
  })
).then(cursos => cursos.filter(Boolean)); // Filtrar nulls
---

<Layout title={`${nombre} — Academia Dental`} description={`Perfil de ${nombre}, docente de Academia Dental Clínica Milenium.`}>

  <PageHero
    title={nombre.replace(/<[^>]+>/g, '')}
    breadcrumb={[{ label: 'Docentes', href: '/docentes' }, { label: nombre.replace(/<[^>]+>/g, '') }]}
  />

  <section class="py-16 px-6 bg-[#F9F9F9]">
    <div class="max-w-7xl mx-auto grid lg:grid-cols-3 gap-10">

      <div class="lg:col-span-2 space-y-8">
        {acf.bio_resumida && (
          <div class="bg-white rounded-2xl border border-light p-8 shadow-sm">
            <h2 class="text-xl font-bold text-dark mb-4">Biografía</h2>
            <div class="prose prose-sm max-w-none text-gray-600" set:html={acf.bio_resumida} />
          </div>
        )}

        {acf.experiencia && acf.experiencia.length > 0 && (
          <div class="bg-white rounded-2xl border border-light p-8 shadow-sm">
            <h2 class="text-xl font-bold text-dark mb-6">Trayectoria</h2>
            <div class="space-y-4">
              {acf.experiencia.map((exp: any) => (
                <div class="flex gap-4">
                  <div class="w-16 shrink-0 text-sm font-bold text-primary pt-0.5">{exp.anio}</div>
                  <div class="text-sm text-gray-600 leading-relaxed border-l-2 border-light pl-4">{exp.descripcion}</div>
                </div>
              ))}
            </div>
          </div>
        )}

        {cursosRelacionados.length > 0 && (
          <div>
            <h2 class="text-xl font-bold text-dark mb-6">Cursos que dicta</h2>
            <div class="grid md:grid-cols-2 gap-6">
              {cursosRelacionados.map((curso: any) => (
                <CourseCard
                  title={curso.post_title ?? curso.title?.rendered}
                  slug={curso.post_name ?? curso.slug}
                  image={getFeaturedImage(curso)}
                  modalidad={curso.acf?.modalidad ?? ''}
                  fecha={curso.acf?.fecha ?? ''}
                  precio={curso.acf?.precio ?? ''}
                />
              ))}
            </div>
          </div>
        )}
      </div>

      <aside class="space-y-6 lg:sticky lg:top-24 self-start">
        <div class="bg-white rounded-2xl border border-light p-6 shadow-sm text-center">
          {foto && (
            <div class="w-32 h-32 mx-auto rounded-full overflow-hidden border-4 border-light mb-4">
              <img src={foto} alt={nombre.replace(/<[^>]+>/g, '')} class="w-full h-full object-cover" />
            </div>
          )}
          <h3 class="font-bold text-dark text-lg mb-2">{nombre.replace(/<[^>]+>/g, '')}</h3>
          {acf.cargo && <p class="text-primary text-sm font-medium mb-1">{acf.cargo}</p>}
          {acf.especialidad && <p class="text-gray-500 text-sm mb-4">{acf.especialidad}</p>}
          <p class="text-sm text-gray-500 mb-4">¿Te interesa un curso con {nombre.replace(/<[^>]+>/g, '')}?</p>
          <a href="/contacto" class="block w-full bg-primary hover:bg-secondary text-white font-bold py-3 rounded-xl transition-colors text-sm mb-3">
            Consultar disponibilidad
          </a>
          <a href="https://wa.me/56912345678" target="_blank" class="flex items-center justify-center gap-2 w-full bg-green-500 hover:bg-green-400 text-white font-semibold py-3 rounded-xl transition-colors text-sm">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp
          </a>
        </div>
      </aside>

    </div>
  </section>

</Layout>
